#!/bin/bash
# pace-maker CLI — uses the managed venv at ~/.claude-pace-maker/venv.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PACEMAKER_DIR="${PACEMAKER_DIR:-$HOME/.claude-pace-maker}"

# shellcheck source=scripts/bootstrap-plugin.sh
source "${SCRIPT_DIR}/bootstrap-plugin.sh"

_bootstrap_resolve_plugin_root

bootstrap_light

if bootstrap_needs_full; then
    if ! bootstrap_full; then
        exit 1
    fi
fi

RUNTIME_PYTHON="$(resolve_runtime_python)" || {
    echo "[pace-maker] Managed venv is not ready. Run: pace-maker doctor" >&2
    exit 1
}

INSTALL_MARKER="$PACEMAKER_DIR/install_source"
if [ -f "$INSTALL_MARKER" ]; then
    SOURCE_DIR="$(cat "$INSTALL_MARKER")"
    if [[ "$SOURCE_DIR" != *"pipx"* ]]; then
        export PYTHONPATH="${SOURCE_DIR}/src${PYTHONPATH:+:${PYTHONPATH}}"
    fi
elif [ -n "${PLUGIN_ROOT:-}" ]; then
    export PYTHONPATH="${PLUGIN_ROOT}/src${PYTHONPATH:+:${PYTHONPATH}}"
fi

exec "$RUNTIME_PYTHON" -m pacemaker.user_commands "$@"
