#!/bin/bash
# pace-maker CLI — uses the managed venv at ~/.claude-pace-maker/venv.
set -euo pipefail

PACEMAKER_DIR="${PACEMAKER_DIR:-$HOME/.claude-pace-maker}"

# ~/.local/bin/pace-maker is a symlink; resolve to the plugin scripts/ directory.
_resolve_cli_script_dir() {
    local script="${BASH_SOURCE[0]}"
    while [ -L "$script" ]; do
        local dir link
        dir="$(cd -P "$(dirname "$script")" && pwd)"
        link="$(readlink "$script")"
        if [[ "$link" == /* ]]; then
            script="$link"
        else
            script="$dir/$link"
        fi
    done
    cd -P "$(dirname "$script")" && pwd
}

SCRIPT_DIR="$(_resolve_cli_script_dir)"
if [ ! -f "${SCRIPT_DIR}/bootstrap-plugin.sh" ]; then
    install_marker="${PACEMAKER_DIR}/install_source"
    if [ -f "$install_marker" ]; then
        SCRIPT_DIR="$(cat "$install_marker")/scripts"
    fi
fi

if [ ! -f "${SCRIPT_DIR}/bootstrap-plugin.sh" ]; then
    echo "[pace-maker] Could not locate bootstrap-plugin.sh (resolved CLI dir: ${SCRIPT_DIR})" >&2
    echo "[pace-maker] Run: pace-maker doctor" >&2
    exit 1
fi

# Pin PLUGIN_ROOT to the resolved CLI script dir's parent BEFORE sourcing
# bootstrap-plugin.sh. Without this, _bootstrap_resolve_plugin_root would
# fall back to an inherited CLAUDE_PLUGIN_ROOT — which is set to a foreign
# plugin's path when the CLI is invoked from another plugin's hook (e.g.
# the developer plugin's SessionStart wiring). That foreign path is then
# used as cli_target by bootstrap_light and rewrites ~/.local/bin/pace-maker
# to a non-existent file under the foreign plugin's scripts/ directory.
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
export PLUGIN_ROOT

# shellcheck source=scripts/bootstrap-plugin.sh
source "${SCRIPT_DIR}/bootstrap-plugin.sh"

_bootstrap_resolve_plugin_root

bootstrap_light

# Skip re-entrant bootstrap (bootstrap_full sets PACEMAKER_BOOTSTRAPPING internally).
if [ "${PACEMAKER_BOOTSTRAPPING:-}" != "1" ] && bootstrap_needs_full; then
    if ! bootstrap_full; then
        echo "[pace-maker] Bootstrap failed. Run: pace-maker doctor" >&2
        echo "[pace-maker] Details: ${PACEMAKER_DIR}/hook_debug.log" >&2
        exit 1
    fi
fi

RUNTIME_PYTHON="$(resolve_runtime_python)" || {
    echo "[pace-maker] Managed venv is not ready. Run: pace-maker doctor" >&2
    exit 1
}

_bootstrap_pythonpath

exec "$RUNTIME_PYTHON" -m pacemaker.user_commands "$@"
